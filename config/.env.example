# BrainPass Configuration
# Copy this to .env and fill in your values. The installer does this for you.

# ─── LLM Provider ────────────────────────────────────────────────────
# Pick ONE:  groq | openai | anthropic | local
LLM_PROVIDER=groq

# ─── Groq (free tier, fastest to get started) ────────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ─── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ─── Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_FALLBACK_MODEL=claude-3-5-haiku-latest

# ─── Local (Ollama / vLLM / anything OpenAI-compatible) ──────────────
LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
LOCAL_LLM_MODEL=llama3.1
LOCAL_LLM_API_KEY=not-needed

# ─── Paths ───────────────────────────────────────────────────────────
VAULT_PATH=~/BrainPass/vault
CACHE_PATH=/tmp/brainpass-topic.txt

# ─── Server ──────────────────────────────────────────────────────────
LIBRARIAN_PORT=7778

# ─── Agent identity defaults (used if SOUL.md is missing) ────────────
AGENT_NAME=Assistant
AGENT_ROLE=Helpful AI

# ─── BM25 Search Tuning (all optional, defaults are good) ────────────
# The search engine scores per-chunk using Okapi BM25. These control
# the scoring behavior. You almost certainly don't need to change them.
BM25_K1=1.5               # [0.5-3.0] term saturation
BM25_B=0.75               # [0.0-1.0] length normalization
CHUNK_SIZE=300             # [50-2000] target words per chunk
CHUNK_MIN=50               # [10-500] min words — merge small chunks
CHUNK_MAX=600              # [200-5000] max words — split large ones
INDEX_TTL=60               # [5-3600] seconds before index rebuild
BM25_MIN_SCORE=0.1         # [0.0-50.0] relevance floor
TAG_BOOST=2.0              # [0.0-3.0] additive boost when query matches a tag
RECENCY_HALF_LIFE=30       # [1-365] days — recency decay half-life
FREQUENCY_BOOST_MAX=1.0    # [0.0-5.0] cap for access-frequency boost
MAX_CHUNKS=10000           # [100-100000] max chunks in index
# STOPWORDS_FILE=          # optional, one-word-per-line custom stopwords

# ─── NotebookLM (optional, for deeper semantic search) ───────────────
# If you upload your vault to https://notebooklm.google.com as a new
# notebook, paste the notebook URL here. The librarian will surface it
# as a fallback when keyword search finds nothing, and the auto-inject
# hook will suggest it in the injected context. Empty = disabled.
NOTEBOOKLM_URL=
