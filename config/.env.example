# BrainPass Configuration
# Copy this to .env and fill in your values

# LLM Provider (choose one)
LLM_PROVIDER=groq
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=local

# API Keys (add your own)
# Primary + fallbacks for rate limiting
GROQ_API_KEY=your_groq_key_here
GROQ_API_KEY_2=your_fallback_key_here_optional
GROQ_API_KEY_3=your_fallback_key_here_optional

OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Local LLM (if using local)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama2

# Model Selection
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Paths (customize for your system)
VAULT_PATH=~/BrainPass/vault
CACHE_PATH=/tmp/brainpass-topic.txt
SESSION_CACHE=/tmp/brainpass-session-cache.json

# Server
LIBRARIAN_PORT=7778

# Agent Identity (fill in your agent's persona)
AGENT_NAME=Assistant
AGENT_ROLE=Helpful AI
