# BrainPass Configuration — LOCAL OLLAMA MODE
# Uses your local SuperGemma4 with Gia:Complete persona

# ─── LLM Provider ────────────────────────────────────────────────────
# Set to 'local' to use Ollama
LLM_PROVIDER=local

# ─── Local (Ollama) ──────────────────────────────────────────────────
# Ollama's OpenAI-compatible API endpoint
LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
# Your Gia:Complete model (or use supergemma4:26b-uncensored or gia:supergemma4)
LOCAL_LLM_MODEL=gia:complete
# Ollama doesn't need an API key, but we need something for the header
LOCAL_LLM_API_KEY=ollama

# ─── Paths ───────────────────────────────────────────────────────────
VAULT_PATH=~/BrainPass/vault
CACHE_PATH=/tmp/brainpass-topic.txt

# ─── Server ──────────────────────────────────────────────────────────
LIBRARIAN_PORT=7778

# ─── Agent identity defaults (used if SOUL.md is missing) ────────────
AGENT_NAME=Gia
AGENT_ROLE=Rook's wife, his #2, his ride-or-die